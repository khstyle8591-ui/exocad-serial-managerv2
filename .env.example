# 서버 환경 설정
HTTP_PORT=3000
HTTPS_PORT=3443
NODE_ENV=production
BIND_HOST=127.0.0.1
ALLOWED_ORIGIN=https://example.com

# 로컬 개발에서만 인증을 끌 수 있습니다. NODE_ENV=production 에서는 금지됩니다.
# AUTH_DISABLED=true

# API Basic Auth
API_USER=admin
# 생성 예: node -e "const bcrypt=require('bcryptjs'); console.log(bcrypt.hashSync('change-me', 12))"
API_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# Reverse proxy 대신 Node HTTPS를 직접 쓸 때만 설정합니다.
# CERT_DOMAIN=geomedi-exocad.duckdns.org
# CERT_DIR=/etc/letsencrypt/live/geomedi-exocad.duckdns.org

# 데이터베이스 경로
# 서버/GCP/마이그레이션/운영 스크립트에서는 필수입니다.
# 데스크톱 앱은 Electron userData/exocad.db를 기본 사용합니다.
DB_PATH=/home/geomedicho/exocad-serial/data/exocad.db

# DB에 저장하지 않는 비밀값
POP3_PASSWORD=
IMAP_PASSWORD=
SMTP_PASSWORD=
EXOCAD_PASSWORD=
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_URL_RELATED=

# 로그 디렉토리 (기본값: process.cwd()/logs)
# LOG_DIR=/home/geomedicho/exocad-serial/logs

# 데이터/스크린샷 디렉토리 (기본값: process.cwd()/data)
# DATA_DIR=/home/geomedicho/exocad-serial/data

# 포털 비밀번호 재설정 링크 기반 URL (예: https://your-domain.com)
PORTAL_BASE_URL=https://your-domain.com

# 로그 회전 정책
LOG_MAX_FILES=14d
LOG_MAX_SIZE=100m
ACTIVITY_LOG_RETENTION_DAYS=180

{
  "name": "exocad-manager",
  "version": "1.0.0",
  "description": "Exocad Serial Number Management Automation",
  "author": "Exocad Manager",
  "main": "dist/main/main/index.js",
  "scripts": {
    "start:server": "node dist/main/server.js",
    "build:server": "tsc -p tsconfig.server.json",
    "build:renderer": "vite build --config vite.config.mts",
    "build": "npm run build:server && npm run build:renderer",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop exocad-serial",
    "pm2:restart": "pm2 restart exocad-serial",
    "pm2:logs": "pm2 logs exocad-serial",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --config vite.config.mts",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron dist/main/main/index.js",
    "build:main": "tsc -p tsconfig.main.json",
    "build:electron": "npm run build:main && npm run build:renderer",
    "start": "electron dist/main/main/index.js",
    "package": "npm run build:electron && node scripts/package.js",
    "dist": "npm run build:electron && electron-builder",
    "postinstall": "node -e \"try{require('@electron/rebuild').rebuild()}catch(e){}\""
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.8",
    "@types/imap": "^0.8.40",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "imap": "^0.8.19",
    "mailparser": "^3.6.5",
    "node-cron": "^3.0.3",
    "node-pop3": "^0.8.0",
    "nodemailer": "^6.9.8",
    "playwright": "^1.41.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.2",
    "xlsx": "^0.18.5"
  }
}
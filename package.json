{
  "name": "exocad-manager",
  "version": "1.0.0",
  "description": "Exocad Serial Number Management Automation",
  "author": "Exocad Manager",
  "main": "dist/main/server.js",
  "scripts": {
    "start:server": "node dist/main/server.js",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:main && npm run build:manager && npm run build:portal",
    "test": "vitest run",
    "test:db": "npm run build:main && node scripts/db-schema-test.cjs",
    "test:watch": "vitest",
    "verify": "npm test && npm run test:db && npm run build",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop exocad-serial",
    "pm2:restart": "pm2 restart exocad-serial",
    "pm2:logs": "pm2 logs exocad-serial",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --config vite.config.mts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:portal": "vite build --config vite.portal.config.ts",
    "build:manager": "vite build --config vite.manager.config.ts",
    "dev:portal": "vite --config vite.portal.config.ts",
    "dev:manager": "vite --config vite.manager.config.ts",
    "postinstall": "npm rebuild better-sqlite3",
    "dev:server": "cross-env HTTP_PORT=3001 node dist/main/server.js",
    "dev:web": "concurrently \"npm run dev:server\" \"npm run dev:renderer\""
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/imap": "^0.8.40",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "imap": "^0.8.19",
    "mailparser": "^3.6.5",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-pop3": "^0.8.0",
    "nodemailer": "^6.9.8",
    "playwright": "^1.41.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.2",
    "recharts": "^3.8.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}

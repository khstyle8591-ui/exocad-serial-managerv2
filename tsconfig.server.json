{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "paths": {
            "@shared/*": [
                "src/shared/*"
            ]
        },
        "baseUrl": "."
    },
    "include": [
        "src/main/**/*",
        "src/server/**/*",
        "src/shared/**/*"
    ],
    "exclude": [
        "src/main/index.ts",
        "src/main/ipc-handlers.ts",
        "src/main/preload.ts"
    ]
}